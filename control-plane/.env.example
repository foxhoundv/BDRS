PORT=8080
REDIS_URL=redis://redis:6379
NATS_URL=nats://event-bus:4222
LOG_LEVEL=info
# Optional override for persisted audio input settings JSON file.
# Default: ./control-plane/audio-input.settings.json
CONTROL_PLANE_AUDIO_SETTINGS_FILE=

# Optional override for baseline audio settings JSON file pulled from repo.
# Default: ./control-plane/audio-input.settings.default.json
CONTROL_PLANE_AUDIO_DEFAULTS_FILE=
