{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "broadcast-rta.bootstrap-config.schema.json",
  "title": "Broadcast RTA Proxmox Bootstrap Config",
  "type": "object",
  "required": [
    "proxmox",
    "template",
    "storage",
    "network",
    "ids",
    "resources",
    "recording",
    "audio",
    "bootstrap"
  ],
  "properties": {
    "proxmox": {
      "type": "object",
      "required": ["host", "port", "node"],
      "properties": {
        "host": { "type": "string", "default": "192.168.1.57" },
        "port": { "type": "integer", "default": 8006, "minimum": 1, "maximum": 65535 },
        "node": { "type": "string", "default": "pve" }
      }
    },
    "template": {
      "type": "object",
      "required": ["choice", "path"],
      "properties": {
        "choice": {
          "type": "string",
          "enum": ["ubuntu-24.04", "ubuntu-22.04", "debian-12"],
          "default": "ubuntu-24.04"
        },
        "path": {
          "type": "string",
          "default": "local:vztmpl/ubuntu-24.04-standard_24.04-2_amd64.tar.zst"
        }
      }
    },
    "storage": {
      "type": "object",
      "required": ["audioEngine", "controlPlane", "recording"],
      "properties": {
        "audioEngine": { "type": "string", "default": "local-lvm" },
        "controlPlane": { "type": "string", "default": "local-lvm" },
        "recording": { "type": "string", "default": "local-lvm" }
      }
    },
    "network": {
      "type": "object",
      "required": ["mode", "bridge", "vlanAudio", "vlanMgmt", "vlanInternet"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["single-bridge-vlan-tags", "separate-bridges"],
          "default": "single-bridge-vlan-tags"
        },
        "bridge": { "type": "string", "default": "vmbr0" },
        "bridgeAudio": { "type": "string", "default": "vmbr10" },
        "bridgeMgmt": { "type": "string", "default": "vmbr20" },
        "bridgeInternet": { "type": "string", "default": "vmbr30" },
        "vlanAudio": { "type": "integer", "default": 10, "minimum": 1, "maximum": 4094 },
        "vlanMgmt": { "type": "integer", "default": 20, "minimum": 1, "maximum": 4094 },
        "vlanInternet": { "type": "integer", "default": 30, "minimum": 1, "maximum": 4094 }
      }
    },
    "ids": {
      "type": "object",
      "required": ["audioEngine", "controlPlane", "recording"],
      "properties": {
        "audioEngine": { "type": "integer", "default": 200 },
        "controlPlane": { "type": "integer", "default": 201 },
        "recording": { "type": "integer", "default": 202 }
      }
    },
    "resources": {
      "type": "object",
      "required": ["audioEngine", "controlPlane", "recording"],
      "properties": {
        "audioEngine": {
          "type": "object",
          "required": ["cores", "memoryMb", "rootfsGb"],
          "properties": {
            "cores": { "type": "integer", "default": 4 },
            "memoryMb": { "type": "integer", "default": 4096 },
            "rootfsGb": { "type": "integer", "default": 8 }
          }
        },
        "controlPlane": {
          "type": "object",
          "required": ["cores", "memoryMb", "rootfsGb"],
          "properties": {
            "cores": { "type": "integer", "default": 2 },
            "memoryMb": { "type": "integer", "default": 2048 },
            "rootfsGb": { "type": "integer", "default": 8 }
          }
        },
        "recording": {
          "type": "object",
          "required": ["cores", "memoryMb"],
          "properties": {
            "cores": { "type": "integer", "default": 6 },
            "memoryMb": { "type": "integer", "default": 8192 }
          }
        }
      }
    },
    "recording": {
      "type": "object",
      "required": ["diskMode", "passthroughRef"],
      "properties": {
        "diskMode": {
          "type": "string",
          "enum": ["virtual-disk", "nvme-passthrough"],
          "default": "virtual-disk"
        },
        "passthroughRef": {
          "type": "string",
          "default": ""
        }
      }
    },
    "audio": {
      "type": "object",
      "required": ["deviceType", "vendorProduct", "generateUdevRule"],
      "properties": {
        "deviceType": { "type": "string", "default": "WING" },
        "vendorProduct": { "type": "string", "default": "" },
        "generateUdevRule": { "type": "boolean", "default": true }
      }
    },
    "bootstrap": {
      "type": "object",
      "required": ["firewallProfile", "startupOrder", "repoUrl", "repoRef", "syncDefaultsFromRepo", "installBuildTooling"],
      "properties": {
        "firewallProfile": {
          "type": "string",
          "enum": ["strict", "default", "open"],
          "default": "default"
        },
        "startupOrder": {
          "type": "string",
          "default": "control-plane,audio-engine,recording"
        },
        "repoUrl": {
          "type": "string",
          "default": "https://github.com/foxhoundv/BDRS.git"
        },
        "repoRef": {
          "type": "string",
          "default": "v0.2.0"
        },
        "syncDefaultsFromRepo": {
          "type": "boolean",
          "default": true
        },
        "installBuildTooling": { "type": "boolean", "default": true }
      }
    }
  }
}
