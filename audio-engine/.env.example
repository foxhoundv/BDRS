# Capture mode: mock or alsa
AUDIO_ENGINE_CAPTURE_MODE=mock

# Input transport backend:
# - alsa_usb: USB mixer capture via ALSA (current implementation)
# - dante: reserved for future implementation
AUDIO_ENGINE_INPUT_TRANSPORT=alsa_usb

# Supported capture rates:
# - alsa_usb: 44100 or 48000
# - dante (future): 44100, 48000, or 96000
# Your current WING setting can be set here, e.g. 44100.
AUDIO_ENGINE_CAPTURE_RATE_HZ=48000

# Capture sample format used by ALSA input:
# - s24_in_32_le: WING-friendly default (24-bit signal in a 32-bit container)
# - s16_le: compatibility mode for devices/paths that require 16-bit capture
AUDIO_ENGINE_SAMPLE_FORMAT=s24_in_32_le

# Payload codec used by the UDP pipeline:
# - pcm16: current default packet payload format
# - opus: optional 20 ms Opus encoding stage (requires 48000 Hz capture)
AUDIO_ENGINE_PAYLOAD_CODEC=pcm16

# Dante source contract (future transport backend): up to 64 sources
AUDIO_ENGINE_DANTE_MAX_SOURCES=64

# ALSA device name when AUDIO_ENGINE_CAPTURE_MODE=alsa
# If unset, audio-engine will try auto-discovery from /proc/asound/cards and
# fall back to "default" when no device can be discovered.
AUDIO_ENGINE_ALSA_DEVICE=default

# Stream mapping format: stream_id:channels;stream_id:channels
# Channels support ranges and lists, e.g. 100:0-1;101:2-3,8
AUDIO_ENGINE_STREAM_GROUPS=100:0-1;101:2-3

# Comma-separated unicast UDP targets (host:port)
# Leave empty to disable UDP transmission while keeping pipeline processing enabled
AUDIO_ENGINE_UDP_TARGETS=127.0.0.1:5004

# Bounded outbound queue depth (>0)
AUDIO_ENGINE_OUTBOUND_QUEUE_DEPTH=1024

# Optional bounded source-visibility test window (seconds).
# Set to 300 for a 5-minute test, leave empty/unset for continuous run.
# AUDIO_ENGINE_TEST_DURATION_SECS=300

# Number of source channels to include in the visibility summary.
# For your current test plan, use 16.
AUDIO_ENGINE_TEST_CHANNEL_COUNT=16
